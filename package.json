{
  "name": "xiaodian-ai-kefu",
  "version": "0.4.2",
  "description": "小店AI客服桌面程序",
  "author": "local",
  "private": true,
  "type": "module",
  "main": "desktop/main.js",
  "scripts": {
    "ai-server": "node server.js",
    "build-extension": "node scripts/build-extension.js",
    "predesktop": "npm run build-extension",
    "prestart": "npm run build-extension",
    "predist": "npm run build-extension",
    "predist:mac": "npm run build-extension",
    "predist:win": "npm run build-extension",
    "check:secrets": "node scripts/check-secrets.js",
    "configure:webhook": "node scripts/configure-wecom-webhook.js",
    "desktop": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "doctor": "node scripts/doctor.js",
    "install:desktop:mac": "bash scripts/install-desktop-launch-agent.sh",
    "install:desktop:win": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\install-desktop-windows.ps1",
    "test:notify-outbox": "node scripts/test-notify-outbox.js",
    "test:baseline": "node scripts/test-behavior-baseline.js",
    "test:desktop-modules": "node scripts/test-desktop-modules.js",
    "test:ai-knowledge": "node scripts/test-ai-knowledge.js",
    "test:security-config": "node scripts/test-security-config.js",
    "test:extension-modules": "node scripts/test-extension-modules.js",
    "test:lifecycle": "node scripts/test-lifecycle.js",
    "test:release-readiness": "node scripts/test-release-readiness.js",
    "test:packaged-resources": "node scripts/check-packaged-resources.js",
    "test:macos-package": "bash scripts/test-macos-package.sh",
    "test:windows-packages": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\test-windows-packages.ps1",
    "test:regressions": "node scripts/test-auth-image-async.js",
    "test:status-ui": "node scripts/test-runtime-status-ui.js",
    "test:webhook": "node scripts/test-wecom-webhook.js",
    "uninstall:desktop:mac": "bash uninstall-desktop-launch-agent.sh",
    "uninstall:desktop:win": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\uninstall-desktop-windows.ps1",
    "start": "node src/index.js run",
    "dry-run": "node src/index.js run --dry-run",
    "inspect": "node src/index.js inspect",
    "inspect-wait": "node src/index.js inspect --wait",
    "login": "node src/index.js login",
    "reply-once": "node src/index.js reply-once"
  },
  "dependencies": {
    "playwright": "^1.52.0"
  },
  "build": {
    "appId": "com.xiaodian-ai-kefu.desktop",
    "productName": "小店AI客服",
    "icon": "build/icon",
    "files": [
      "desktop/**/*",
      "extension/**/*",
      "config/**/*",
      "knowledge-base/**/*",
      "src/**/*",
      "docs/**/*",
      "server.js",
      "package.json"
    ],
    "asarUnpack": [
      "config/reply-images/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business",
      "icon": "build/icon.icns",
      "identity": null
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 270,
          "y": 360,
          "type": "file",
          "path": "docs/mac-install-troubleshooting.md"
        },
        {
          "x": 270,
          "y": 430,
          "type": "file",
          "path": "scripts/repair-macos-install.command"
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.25.12"
  }
}
