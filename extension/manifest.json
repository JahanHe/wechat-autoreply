{
  "manifest_version": 3,
  "name": "小店AI客服",
  "version": "0.3.6",
  "description": "在微信小店客服页本地监听新会话，并按规则自动回复。",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*",
    "https://store.weixin.qq.com/*"
  ],
  "action": {
    "default_title": "小店AI客服",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://store.weixin.qq.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
